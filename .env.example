# ---- Postgres ----
POSTGRES_USER=harbor
POSTGRES_PASSWORD=harbor
POSTGRES_DB=harbor

# ---- Provider selection ----
# "mock"  -> deterministic offline provider, no API key needed (default)
# "openai" -> any OpenAI-compatible endpoint (OpenAI, Ollama, vLLM, ...)
PROVIDER=mock

# Used only when PROVIDER=openai.
# OpenAI:  https://api.openai.com/v1
# Ollama:  http://host.docker.internal:11434/v1   (model e.g. llama3.1)
# vLLM:    http://host.docker.internal:8001/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
PRIMARY_MODEL=gpt-4o-mini

# ---- Retrieval ----
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
TOP_K=4

# ---- Gateway: semantic cache (Week 2) ----
CACHE_ENABLED=true
# Cosine similarity in [0,1]; a lookup hits when best match >= threshold.
CACHE_THRESHOLD=0.92
CACHE_MAX_ENTRIES=5000
# Per-token pacing when replaying a cached response as a stream (0 = instant).
CACHE_REPLAY_PACING_MS=3

# ---- Gateway: rate limiting (Redis + Lua token bucket) ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=1000
RATE_LIMIT_BURST=2000

# ---- Mock provider ----
# Simulated per-token latency. Raise (e.g. 40) to emulate real inference and
# make the cache latency win obvious in `make bench`.
MOCK_TOKEN_DELAY_MS=12

# ---- Gateway: routing (Week 2b) ----
CHEAP_MODEL=harbor-small
STRONG_MODEL=harbor-large
# Prompt size (approx tokens) at/above which a request routes to the strong model.
ROUTE_TOKEN_THRESHOLD=400

# ---- Gateway: fallback + circuit breaker (Week 2b) ----
# Fraction (0..1) of primary calls to fail on purpose. Set to 1.0 to demo
# fallback + the breaker opening; leave 0 for normal operation.
PRIMARY_FAULT_RATE=0
BREAKER_THRESHOLD=5
BREAKER_COOLDOWN_SECONDS=15
