# ---- Postgres ----
POSTGRES_USER=harbor
POSTGRES_PASSWORD=harbor
POSTGRES_DB=harbor

# ---- Provider selection ----
# "mock"  -> deterministic offline provider, no API key needed (default)
# "openai" -> any OpenAI-compatible endpoint (OpenAI, Ollama, vLLM, ...)
PROVIDER=mock

# Used only when PROVIDER=openai.
# OpenAI:  https://api.openai.com/v1
# Ollama:  http://host.docker.internal:11434/v1   (model e.g. llama3.1)
# vLLM:    http://host.docker.internal:8001/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
PRIMARY_MODEL=gpt-4o-mini

# ---- Retrieval ----
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
TOP_K=4
